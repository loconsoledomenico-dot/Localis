---
export const prerender = true;
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import GuideCard from '../components/GuideCard.astro';
import TrailerPlayer from '../components/TrailerPlayer.astro';
import PriceCard from '../components/PriceCard.astro';
import SectionDivider from '../components/SectionDivider.astro';
import JourneyOverview from '../components/JourneyOverview.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import StatsBlock from '../components/StatsBlock.astro';
import StepsBlock from '../components/StepsBlock.astro';
import AuthorsBlock from '../components/AuthorsBlock.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides'))
  .filter((g) => g.data.city === 'bari')
  .sort((a, b) => a.data.published_at.getTime() - b.data.published_at.getTime());

const liveGuides = guides.filter((g) => g.data.status === 'live');

const featuredTrailer = liveGuides[0]; // Bari Vecchia
---
<Layout
  title="Localis — audioguide narrative di Bari"
  description="Sei guide narrative di Bari. Storie vere registrate sui luoghi reali. Senza app, dal browser. Per sempre tue. Da €4,99."
  lang="it"
>
  <Hero lang="it" />

  {/* TRAILER — primary action: prova prima di comprare */}
  <section id="assaggio" class="bg-surface">
    <div class="max-w-narrow mx-auto px-md py-2xl lg:py-3xl">
      <SectionDivider label="Sessanta secondi prima di decidere" />
      {featuredTrailer && (
        <TrailerPlayer
          src={featuredTrailer.data.audio_trailer_path}
          label={`Anteprima · ${featuredTrailer.data.title_it.split('—')[0].trim()}`}
          lang="it"
        />
      )}
      <p class="text-center font-display italic text-xl sm:text-2xl text-ink-muted mt-lg max-w-prose mx-auto leading-snug">
        Fermati. Guarda il mare davanti a te.<br />
        Questo non è uno sfondo: è il posto dove tutto è successo.
      </p>
    </div>
  </section>

  {/* JOURNEY — i cinque gesti dell'esperienza */}
  <JourneyOverview lang="it" />

  {/* FEATURE BLOCK 1 — Storie sui luoghi (image right) */}
  <FeatureBlock
    eyebrow="Storie — Tav. II"
    heading="Non ti diciamo cosa vedere."
    italicEnding="Ti diciamo cosa è successo."
    body="Ogni capitolo è una storia vera, costruita su un punto preciso: un cortile, un altare laterale, l'angolo dove un mercante è morto in piedi. Niente itinerari da brochure. Niente «benvenuti a Bari». Solo nomi, date, dettagli che nessuno ti racconta a meno che non sia di qui."
    bullets={[
      'Capitoli da 6–12 minuti, scritti per la lunghezza di un vicolo',
      'Geo-trigger automatico: parte quando arrivi nel punto giusto',
      'Niente musica di sottofondo. Solo voce e silenzio fra una frase e l\'altra',
      'Fonti citate · ricerca d\'archivio, non Wikipedia',
    ]}
    imageSrc="/images/covers/bari-vecchia.jpg"
    imageAlt="Vicolo del Borgo Antico di Bari, pietre consumate e arco normanno"
    plateNumber="Tav. II"
    caption="Strada delle Crociate, Bari Vecchia. La pietra è la stessa del 1156."
    ctaLabel="Ascolta il primo capitolo"
    ctaHref="#assaggio"
    imageSide="right"
  />

  {/* FEATURE BLOCK 2 — Niente app, niente account (image left) */}
  <FeatureBlock
    eyebrow="Strumento — Tav. III"
    heading="Funziona dal browser."
    italicEnding="Anche offline. Anche senza segnale."
    body="Apri il link, premi play. Niente da scaricare, niente registrazione, niente cookie banner. La prima volta che ascolti un capitolo, l'audio resta sul telefono — e funziona anche dopo, nei vicoli stretti dove il GPS si confonde e il 4G sparisce. Pensato per passeggeri di crociera senza roaming, e per chi non vuole un'altra icona sul telefono."
    bullets={[
      'Su iPhone, Android, qualsiasi browser moderno',
      'Audio cache automatica · senti tutto anche offline',
      'Nessun account, nessuna email obbligatoria',
      'Italiano e inglese · voci registrate da madrelingua',
    ]}
    imageSrc="/images/covers/porto-bari.jpg"
    imageAlt="Porto vecchio di Bari, barche e Teatro Margherita"
    plateNumber="Tav. III"
    caption="Lungomare Imperatore Augusto. Il punto da cui partono tutte le edizioni."
    ctaLabel="Vedi le sei guide"
    ctaHref="#guide"
    imageSide="left"
  />

  {/* FEATURE BLOCK 3 — Voci e firme (image right) */}
  <FeatureBlock
    eyebrow="Voci — Tav. IV"
    heading="Sei narratori baresi."
    italicEnding="Ognuno racconta il suo quartiere."
    body="Non attori, non turisti, non guide certificate. Voci di chi è cresciuto sotto quegli archi, ha mangiato in quei panifici, ha visto cambiare quei mercati. Ogni guida è firmata: nome, foto, due righe su perché proprio lui o lei. Il timbro è quello di un amico che ti porta a casa sua — non di una segreteria turistica."
    bullets={[
      'Sei autori distinti, uno per quartiere',
      'Bio breve · puoi sapere chi ti sta parlando',
      'Tono editoriale · niente entusiasmo finto, niente «mamma mia»',
      'Versione inglese non tradotta · scritta da zero per orecchie anglofone',
    ]}
    imageSrc="/images/covers/tre-teatri.jpg"
    imageAlt="Teatro Petruzzelli di Bari, facciata neoclassica al tramonto"
    plateNumber="Tav. IV"
    caption="Teatro Petruzzelli, Murat. La voce della guida ci ha visto la prima opera a sei anni."
    ctaLabel="Conosci gli autori"
    ctaHref="/about"
    imageSide="right"
  />

  {/* STATS — numeri onesti, niente vanity metrics */}
  <StatsBlock lang="it" />

  {/* GUIDE — mobile snap carousel · desktop grid */}
  <section id="guide" class="bg-surface">
    <div class="max-w-wrap mx-auto px-md py-2xl lg:py-3xl">
      <SectionDivider label="Le sei guide di Bari" />

      <div class="
        guides-row
        flex md:grid md:grid-cols-2 lg:grid-cols-3 gap-md
        overflow-x-auto md:overflow-visible
        snap-x snap-mandatory md:snap-none
        -mx-md md:mx-0 px-md md:px-0 pb-md md:pb-0
        scroll-pl-md
      ">
        {guides.map((g, i) => (
          <div
            class="guide-cell snap-start shrink-0 w-[82%] sm:w-[60%] md:w-auto"
            style={`--idx:${i}`}
          >
            <GuideCard guide={g} lang="it" index={i} />
          </div>
        ))}
      </div>

      <p class="md:hidden text-center text-[11px] text-ink-subtle mt-md tracking-[0.18em] uppercase font-semibold">
        scorri per vedere tutte
      </p>
    </div>
  </section>

  {/* MANIFESTO — pull-quote editoriale, parchment, ornamento tipografico */}
  <section class="bg-surface-elev">
    <div class="max-w-narrow mx-auto px-md py-3xl lg:py-4xl">
      <p class="text-center text-[10px] font-semibold tracking-[0.32em] uppercase text-ink-subtle mb-2xl">
        — Manifesto —
      </p>

      <blockquote class="manifesto-quote relative font-display italic text-ink leading-[1.18] text-[clamp(1.8rem,4.6vw,2.8rem)] m-0 max-w-[26ch] mx-auto text-center">
        <span aria-hidden="true" class="font-display not-italic font-light text-accent text-[3em] leading-none absolute -top-md sm:-top-lg left-1/2 -translate-x-[110%] select-none">«</span>
        Queste non sono guide turistiche.
        <span aria-hidden="true" class="font-display not-italic font-light text-accent text-[3em] leading-none absolute -bottom-md sm:-bottom-lg left-1/2 translate-x-[10%] select-none">»</span>
      </blockquote>

      <div class="flex items-center justify-center gap-sm my-2xl" aria-hidden="true">
        <span class="block w-8 h-px bg-border"></span>
        <span class="font-display italic text-ink-subtle text-base">✻</span>
        <span class="block w-8 h-px bg-border"></span>
      </div>

      <p class="text-center text-base sm:text-lg leading-relaxed text-ink-muted max-w-[52ch] mx-auto">
        Non ti diciamo dove mangiare. Non ti diciamo cosa evitare.<br class="hidden sm:inline" />
        Ti raccontiamo le storie vere dei luoghi — mentre ci stai dentro.
      </p>
    </div>
  </section>

  {/* TAVOLE AUTORI — sei voci baresi, una per quartiere */}
  <AuthorsBlock lang="it" />

  {/* 3-PASSI — onboarding chiaro prima del pricing */}
  <StepsBlock lang="it" ctaHref="#assaggio" />

  {/* PRICING */}
  <section id="prezzi" class="bg-surface">
    <div class="max-w-wrap mx-auto px-md py-2xl lg:py-3xl">
      <SectionDivider label="Prendi quella che ti serve" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-md max-w-[48rem] mx-auto">
        <PriceCard
          product="single"
          guideSlug="bari-vecchia"
          lang="it"
          features={[
            'Una guida a tua scelta',
            'Accesso illimitato, per sempre',
            'Funziona offline · Senza app',
            'Italiano e inglese',
          ]}
        />
        <PriceCard
          product="bundle"
          lang="it"
          primary
          features={[
            'Tutte e tre le guide live di Bari',
            'Sequenza progettata: ~4h di cammino',
            'Risparmi €4,98',
            'Per sempre tue',
          ]}
        />
      </div>
    </div>
  </section>

  {/* CLOSER */}
  <section class="bg-surface">
    <div class="max-w-wrap mx-auto px-md py-3xl lg:py-4xl text-center">
      <p class="font-display italic text-xl sm:text-2xl text-ink-muted mb-2xs">
        Bari si visita in un giorno.
      </p>
      <p class="font-display text-3xl sm:text-4xl text-ink mb-lg leading-tight">
        Si capisce in tre voci.
      </p>
      <a
        href="#guide"
        class="inline-flex items-center justify-center gap-xs px-lg py-md bg-ink text-surface rounded-md font-semibold text-sm hover:bg-ink/90 transition-[background-color,transform] duration-fast hover:-translate-y-[1px] active:translate-y-0 no-underline min-h-[48px]"
      >
        Inizia ad ascoltare
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Stagger reveal per guide cards. Index passato via custom prop --idx. */
  .guide-cell {
    opacity: 0;
    transform: translateY(16px);
    animation: guideCellIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--idx, 0) * 80ms + 120ms);
  }
  @keyframes guideCellIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Nasconde scrollbar orizzontale mobile, mantiene momentum */
  .guides-row {
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .guides-row::-webkit-scrollbar { display: none; }

  /* Manifesto: leggera comparsa del blockquote alla prima paint */
  .manifesto-quote {
    opacity: 0;
    transform: translateY(10px);
    animation: manifestoIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }
  @keyframes manifestoIn {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .guide-cell,
    .manifesto-quote {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
