---
import { type Lang } from '../lib/i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const eyebrow = lang === 'it' ? 'Tavola II — Il viaggio' : 'Plate II — The journey';
const heading = lang === 'it' ? 'Dall\'inizio alla fine, in cinque gesti.' : 'From start to finish, in five gestures.';
const scrollHint = lang === 'it' ? 'Scorri per vedere tutti' : 'Scroll to see all';
const allLabel = lang === 'it' ? 'Cinque tavole' : 'Five plates';

const steps = lang === 'it'
  ? [
      { n: '01', verb: 'Apri', body: 'Un link nel browser. Niente download, niente account.', flourish: 'browser' },
      { n: '02', verb: 'Scegli', body: 'Una guida fra le sei. Per quartiere o per umore.', flourish: 'guide' },
      { n: '03', verb: 'Cammina', body: 'I capitoli partono nei punti giusti, mentre sei lì.', flourish: 'walk' },
      { n: '04', verb: 'Ascolta', body: 'Voce a bassa voce. Storie vere, dettate dai luoghi.', flourish: 'listen' },
      { n: '05', verb: 'Riascolta', body: 'Per sempre tua. Anche fra dieci anni, anche da casa.', flourish: 'replay' },
    ]
  : [
      { n: '01', verb: 'Open', body: 'A link in your browser. No download, no signup.', flourish: 'browser' },
      { n: '02', verb: 'Choose', body: 'One of six guides. By neighbourhood or by mood.', flourish: 'guide' },
      { n: '03', verb: 'Walk', body: 'Chapters start in the right places, while you\'re there.', flourish: 'walk' },
      { n: '04', verb: 'Listen', body: 'A low voice. Real stories dictated by the places.', flourish: 'listen' },
      { n: '05', verb: 'Replay', body: 'Yours forever. In ten years, from home, anywhere.', flourish: 'replay' },
    ];
---
<section class="journey bg-surface">
  <div class="max-w-wrap mx-auto px-md sm:px-lg pt-2xl lg:pt-3xl pb-xl lg:pb-2xl">

    <!-- Header: eyebrow + heading -->
    <div class="journey-header flex flex-col sm:flex-row sm:items-end sm:justify-between gap-md mb-2xl">
      <div>
        <div class="flex items-center gap-sm mb-sm">
          <span class="block w-7 h-px bg-accent"></span>
          <span class="text-[11px] font-semibold tracking-[0.24em] uppercase text-accent">
            {eyebrow}
          </span>
        </div>
        <h2 class="font-display text-ink text-[clamp(1.7rem,3.6vw,2.4rem)] leading-[1.1] tracking-[-0.012em] max-w-[26ch] m-0">
          {heading}
        </h2>
      </div>

      <!-- Counter pill (decorative track marker) -->
      <span class="font-body text-[11px] font-semibold tracking-[0.22em] uppercase text-ink-subtle whitespace-nowrap pb-1">
        {allLabel}
      </span>
    </div>
  </div>

  <!-- Scroll-snap track — bleeds to viewport edges, scrollbar hidden -->
  <div class="journey-track-wrap relative">
    <ol class="journey-track" role="list">
      {steps.map((s, i) => (
        <li
          class="journey-card snap-start shrink-0"
          style={`--idx:${i}`}
          data-flourish={s.flourish}
        >
          <article class="journey-card-inner">
            <header class="journey-card-head">
              <span class="font-body font-semibold text-[10px] tracking-[0.32em] uppercase text-ink-subtle">
                {s.n} {' / '} 05
              </span>
              <svg class="journey-flourish" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                {s.flourish === 'browser' && (
                  <>
                    <rect x="2" y="4" width="16" height="12" rx="1.5"/>
                    <line x1="2" y1="8" x2="18" y2="8"/>
                    <circle cx="4.5" cy="6" r="0.5" fill="currentColor"/>
                  </>
                )}
                {s.flourish === 'guide' && (
                  <>
                    <path d="M4 3 L4 17 L10 14 L16 17 L16 3 L10 6 Z"/>
                  </>
                )}
                {s.flourish === 'walk' && (
                  <>
                    <circle cx="11" cy="4" r="1.5"/>
                    <path d="M8 17 L9 13 L7 11 L8 8 L11 7 L13 9 L15 9"/>
                    <path d="M9 13 L11 14 L11 17"/>
                  </>
                )}
                {s.flourish === 'listen' && (
                  <>
                    <path d="M5 10 a5 5 0 0 1 10 0 v4 h-2 v-4 a3 3 0 0 0 -6 0 v4 h-2 z"/>
                    <path d="M5 14 v-4 M15 14 v-4" stroke-linecap="round"/>
                  </>
                )}
                {s.flourish === 'replay' && (
                  <>
                    <path d="M3 10 a7 7 0 1 1 2.5 5.4"/>
                    <polyline points="3 8 3 11 6 11"/>
                  </>
                )}
              </svg>
            </header>

            <div class="journey-card-body">
              <span class="journey-numeral" aria-hidden="true">{s.n}</span>
              <h3 class="journey-verb font-display text-ink leading-none m-0">
                {s.verb}
              </h3>
              <p class="journey-body font-body text-base text-ink-muted leading-snug m-0">
                {s.body}
              </p>
            </div>

            <footer class="journey-card-foot" aria-hidden="true">
              <span class="block w-8 h-px bg-border"></span>
              <span class="font-display italic text-ink-subtle text-base leading-none">✻</span>
              <span class="block flex-1 h-px bg-border"></span>
            </footer>
          </article>
        </li>
      ))}
    </ol>

    <!-- Edge fade gradients (visual cue that more content exists) -->
    <span class="journey-fade journey-fade-l" aria-hidden="true"></span>
    <span class="journey-fade journey-fade-r" aria-hidden="true"></span>
  </div>

  <!-- Scroll hint -->
  <div class="max-w-wrap mx-auto px-md sm:px-lg pb-2xl lg:pb-3xl">
    <p class="journey-hint flex items-center gap-sm text-[11px] font-semibold tracking-[0.22em] uppercase text-ink-subtle mt-md">
      <svg width="22" height="10" viewBox="0 0 22 10" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
        <line x1="0" y1="5" x2="20" y2="5"/>
        <polyline points="16 1 20 5 16 9"/>
      </svg>
      {scrollHint}
    </p>
  </div>
</section>

<style>
  .journey-track-wrap {
    position: relative;
    width: 100%;
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: var(--spacing-md);
    border-top: 1px solid var(--color-ink);
  }
  @media (min-width: 640px) {
    .journey-track-wrap {
      padding-inline: var(--spacing-lg);
    }
  }

  .journey-track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--spacing-md);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-padding-left: 0;
  }
  .journey-track::-webkit-scrollbar {
    display: none;
  }
  @media (min-width: 640px) {
    .journey-track {
      gap: var(--spacing-lg);
    }
  }

  .journey-card {
    flex: 0 0 auto;
    width: clamp(240px, 78vw, 320px);
    scroll-snap-align: start;
    opacity: 0;
    transform: translateY(14px);
    animation: journeyIn 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--idx, 0) * 80ms + 100ms);
  }

  @media (min-width: 1024px) {
    .journey-card {
      width: 300px;
    }
  }

  .journey-card-inner {
    position: relative;
    height: 100%;
    min-height: 280px;
    padding: var(--spacing-lg) var(--spacing-md) var(--spacing-md);
    display: flex;
    flex-direction: column;
  }

  /* Discreet hover: numeral lights up, asterisk turns accent */
  .journey-card:hover .journey-numeral,
  .journey-card:focus-within .journey-numeral {
    opacity: 0.18;
  }
  .journey-card:hover .journey-card-foot span:nth-child(2),
  .journey-card:focus-within .journey-card-foot span:nth-child(2) {
    color: var(--color-accent);
  }
  .journey-numeral,
  .journey-card-foot span:nth-child(2) {
    transition: opacity 250ms cubic-bezier(0.22, 1, 0.36, 1),
                color 250ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .journey-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-2xl);
    color: var(--color-ink-subtle);
  }

  .journey-flourish {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .journey-card-body {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: var(--spacing-lg);
  }

  /* Background numeral — large Spectral italic, low opacity */
  .journey-numeral {
    position: absolute;
    top: -1.2rem;
    left: -0.3rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(5rem, 12vw, 7rem);
    line-height: 0.8;
    color: var(--color-accent);
    opacity: 0.10;
    user-select: none;
    pointer-events: none;
    letter-spacing: -0.04em;
  }

  .journey-verb {
    font-weight: 300;
    font-size: clamp(2.4rem, 4.4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-sm);
    position: relative;
  }

  .journey-body {
    max-width: 26ch;
    position: relative;
  }

  .journey-card-foot {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-top: auto;
    padding-top: var(--spacing-md);
  }

  /* Edge fades — subtle visual cue for scrollable region */
  .journey-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(24px, 4vw, 60px);
    pointer-events: none;
    z-index: 1;
  }
  .journey-fade-l {
    left: 0;
    background: linear-gradient(to right, var(--color-surface), transparent);
  }
  .journey-fade-r {
    right: 0;
    background: linear-gradient(to left, var(--color-surface), transparent);
  }

  /* Hint arrow gentle nudge */
  .journey-hint svg {
    animation: hintNudge 2.4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes journeyIn {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes hintNudge {
    0%, 60%, 100% { transform: translateX(0); }
    30% { transform: translateX(3px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .journey-card,
    .journey-hint svg {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
