---
import { type Lang } from '../lib/i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const eyebrow = lang === 'it' ? 'Tavola VII — I sei luoghi' : 'Plate VII — The six places';
const heading1 = lang === 'it' ? 'Cinque storie tracciate.' : 'Five stories traced.';
const heading2 = lang === 'it' ? 'Una sesta in arrivo.' : 'A sixth on its way.';
const intro = lang === 'it'
  ? 'Cinque guide narrative legate a sei luoghi precisi del centro storico di Bari. La sesta — già confermata — esce a giorni. Tocca un riquadro per ascoltare.'
  : 'Five narrative guides anchored to six precise places in central Bari. The sixth — already confirmed — comes shortly. Tap a tile to listen.';

interface Place {
  slug: string;
  title: string;
  duration: string;
  quartiere: string;
  startsAt: string;
  cover: string;
  alt: string;
  draft?: boolean;
}

const places: Place[] = lang === 'it'
  ? [
      {
        slug: 'bari-vecchia',
        title: 'Bari Vecchia — Dentro la Città',
        duration: '9 min',
        quartiere: 'Borgo Antico',
        startsAt: 'Strada delle Crociate',
        cover: '/images/covers/bari-vecchia.jpg',
        alt: 'Vicolo del Borgo Antico di Bari con colonne romane antiche e palazzi storici',
      },
      {
        slug: 'san-nicola',
        title: 'San Nicola — Il Santo Rubato',
        duration: '7 min',
        quartiere: 'Borgo Antico',
        startsAt: 'Basilica di San Nicola',
        cover: '/images/covers/san-nicola.jpg',
        alt: 'Vicolo di Bari Vecchia con luminaria di festa che incornicia la prospettiva',
      },
      {
        slug: 'il-meglio-di-bari',
        title: 'Il Meglio di Bari — Mangia Prima di Capire',
        duration: '8 min',
        quartiere: 'Borgo Antico',
        startsAt: 'Strada Arco Basso',
        cover: '/images/covers/il-meglio-di-bari.jpg',
        alt: 'Strada delle Orecchiette a Bari Vecchia, donne che lavorano la pasta su tavoli di legno e cappelli appesi tra i vicoli',
      },
      {
        slug: 'porto-bari',
        title: 'Porto di Bari — Dove è Successo Tutto',
        duration: '8 min',
        quartiere: 'Lungomare',
        startsAt: 'Molo San Nicola',
        cover: '/images/covers/porto-bari.jpg',
        alt: 'Bari dall\'alto al tramonto, lungomare e marina del porto turistico',
      },
      {
        slug: 'tre-teatri',
        title: 'I Tre Teatri — Fuoco, Musica e Borghesia',
        duration: '10 min',
        quartiere: 'Murat',
        startsAt: 'Teatro Petruzzelli',
        cover: '/images/covers/tre-teatri.jpg',
        alt: 'Teatro Petruzzelli di Bari, facciata neoclassica al tramonto',
      },
      {
        slug: '__draft',
        title: 'Capitolo 06 — In arrivo',
        duration: '— —',
        quartiere: 'In registrazione',
        startsAt: 'Voce confermata, dettagli a giorni',
        cover: '',
        alt: '',
        draft: true,
      },
    ]
  : [
      {
        slug: 'bari-vecchia',
        title: 'Old Bari — Inside the City',
        duration: '9 min',
        quartiere: 'Old town',
        startsAt: 'Strada delle Crociate',
        cover: '/images/covers/bari-vecchia.jpg',
        alt: 'Old Bari alley with ancient Roman columns and historic buildings',
      },
      {
        slug: 'san-nicola',
        title: 'San Nicola — The Stolen Saint',
        duration: '7 min',
        quartiere: 'Old town',
        startsAt: 'Basilica di San Nicola',
        cover: '/images/covers/san-nicola.jpg',
        alt: 'Old Bari alley framed by a feast luminaria arch',
      },
      {
        slug: 'il-meglio-di-bari',
        title: 'The Best of Bari — Eat Before You Think',
        duration: '8 min',
        quartiere: 'Old town',
        startsAt: 'Strada Arco Basso',
        cover: '/images/covers/il-meglio-di-bari.jpg',
        alt: 'The Orecchiette Street in Old Bari, women shaping pasta on wooden tables, hats hanging between alleys',
      },
      {
        slug: 'porto-bari',
        title: 'Port of Bari — Where It All Happened',
        duration: '8 min',
        quartiere: 'Lungomare',
        startsAt: 'Molo San Nicola',
        cover: '/images/covers/porto-bari.jpg',
        alt: 'Aerial view of Bari at sunset, lungomare and tourist marina visible',
      },
      {
        slug: 'tre-teatri',
        title: 'The Three Theatres — Fire, Music, Bourgeoisie',
        duration: '10 min',
        quartiere: 'Murat',
        startsAt: 'Teatro Petruzzelli',
        cover: '/images/covers/tre-teatri.jpg',
        alt: 'Petruzzelli Theatre of Bari, neoclassical facade at dusk',
      },
      {
        slug: '__draft',
        title: 'Chapter 06 — Coming',
        duration: '— —',
        quartiere: 'In recording',
        startsAt: 'Voice confirmed, details soon',
        cover: '',
        alt: '',
        draft: true,
      },
    ];

const guidePathPrefix = lang === 'it' ? '/guide/' : '/en/guide/';
const startsLabel = lang === 'it' ? 'Parte da' : 'Starts at';
const comingLabel = lang === 'it' ? 'In arrivo' : 'Coming';
---
<section id="guide" class="places-section bg-surface scroll-mt-lg">
  <div class="max-w-wrap mx-auto px-md sm:px-lg py-2xl lg:py-3xl">

    <!-- Section header -->
    <div class="places-header max-w-[60ch] mb-2xl lg:mb-3xl">
      <div class="flex items-center gap-sm mb-md">
        <span class="block w-7 h-px bg-accent"></span>
        <span class="text-[11px] font-semibold tracking-[0.24em] uppercase text-accent">
          {eyebrow}
        </span>
      </div>
      <h2 class="font-display text-ink leading-[1.05] tracking-[-0.014em] mb-md text-[clamp(1.9rem,4.4vw,3rem)]">
        <span class="font-light">{heading1}</span>
        <em class="block font-normal italic text-accent mt-2xs text-[clamp(1.7rem,3.8vw,2.6rem)]">
          {heading2}
        </em>
      </h2>
      <p class="font-body text-base sm:text-lg leading-relaxed text-ink-muted">
        {intro}
      </p>
    </div>

    <!-- Photo grid -->
    <ol class="places-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-lg gap-y-2xl list-none p-0 m-0">
      {places.map((p, i) => {
        const num = String(i + 1).padStart(2, '0');
        const isDraft = p.draft === true;
        const linkHref = isDraft ? '#guide' : `${guidePathPrefix}${p.slug}`;
        return (
          <li class="place-cell" style={`--idx:${i}`}>
            <a
              href={linkHref}
              class={`place-card ${isDraft ? 'is-draft' : ''}`}
              aria-label={isDraft ? `${comingLabel}: ${p.title}` : `${p.title} — ${startsLabel} ${p.startsAt}`}
            >
              <!-- Photo / placeholder -->
              <figure class="place-photo m-0">
                {!isDraft && p.cover ? (
                  <img
                    src={p.cover}
                    alt={p.alt}
                    class="place-img"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="place-empty" aria-hidden="true">
                    <span class="place-empty-mark">06</span>
                    <span class="place-empty-label">{comingLabel}</span>
                  </div>
                )}
                <!-- Number stamp -->
                <span class="place-num" aria-hidden="true">{num}</span>
                <!-- Bottom scrim with eyebrow -->
                {!isDraft && (
                  <span class="place-scrim" aria-hidden="true">
                    <span class="place-quartiere">{p.quartiere}</span>
                    <span class="place-duration">{p.duration}</span>
                  </span>
                )}
              </figure>

              <!-- Meta below photo -->
              <div class="place-meta">
                <h3 class="place-title font-display text-ink leading-[1.2] m-0">
                  <span class="font-light">{p.title}</span>
                </h3>
                <p class="place-starts m-0">
                  <span class="place-starts-label">{startsLabel}</span>
                  <em class="place-starts-where">{p.startsAt}</em>
                </p>
              </div>
            </a>
          </li>
        );
      })}
    </ol>
  </div>
</section>

<style>
  .place-cell {
    opacity: 0;
    transform: translateY(14px);
    animation: placeIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--idx, 0) * 80ms + 100ms);
  }

  .place-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    text-decoration: none;
    color: inherit;
    border-top: 1px solid var(--color-ink);
    padding-top: var(--spacing-md);
    transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .place-card.is-draft {
    border-top-style: dashed;
    border-top-color: var(--color-border);
  }

  .place-card:hover {
    transform: translateY(-2px);
  }

  /* Photo */
  .place-photo {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--color-surface-elev);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .place-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.94) contrast(1.04);
    transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .place-card:hover .place-img,
  .place-card:focus-visible .place-img {
    transform: scale(1.03);
  }

  /* Empty placeholder for the 6th tile */
  .place-empty {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    background:
      radial-gradient(ellipse at 50% 40%, oklch(78% 0.012 75) 0%, oklch(78% 0.012 75) 28%, transparent 48%),
      var(--color-surface-elev);
  }
  .place-empty-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(4rem, 9vw, 6rem);
    line-height: 1;
    color: var(--color-accent);
    letter-spacing: -0.04em;
    user-select: none;
    opacity: 0.55;
  }
  .place-empty-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }

  /* Number stamp top-left of photo */
  .place-num {
    position: absolute;
    top: var(--spacing-sm);
    left: var(--spacing-sm);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.4rem, 4.4vw, 3.2rem);
    line-height: 0.85;
    color: var(--color-surface);
    letter-spacing: -0.04em;
    text-shadow: 0 1px 8px oklch(15% 0.012 240 / 0.55);
    pointer-events: none;
    user-select: none;
  }
  .is-draft .place-num {
    display: none;
  }

  /* Bottom scrim with quartiere + duration */
  .place-scrim {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) var(--spacing-md);
    background: linear-gradient(to top, oklch(15% 0.012 240 / 0.78), transparent 100%);
    color: var(--color-surface);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    pointer-events: none;
  }
  .place-quartiere {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .place-duration {
    flex-shrink: 0;
    color: var(--color-accent-soft);
  }

  /* Meta */
  .place-meta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }
  .place-title {
    font-size: clamp(1.1rem, 2.4vw, 1.35rem);
  }
  .place-starts {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--spacing-xs);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }
  .place-starts-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }
  .place-starts-where {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-accent);
  }

  /* Draft cell tones down meta */
  .is-draft .place-title,
  .is-draft .place-starts-where {
    color: var(--color-ink-subtle);
  }

  .place-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  @keyframes placeIn {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .place-cell,
    .place-card,
    .place-img {
      animation: none !important;
      transition: none !important;
      opacity: 1;
      transform: none;
    }
  }
</style>
