---
import { type Lang } from '../lib/i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const eyebrow = lang === 'it' ? 'Tavola V — I numeri' : 'Plate V — The numbers';
const heading = lang === 'it'
  ? 'Una sola città. Sei voci. Centoventi minuti che non si dimenticano.'
  : 'One city. Six voices. One hundred and twenty minutes you don\'t forget.';

const stats = lang === 'it'
  ? [
      { value: '6', target: 6, suffix: '', label: 'guide narrative · sei quartieri di Bari' },
      { value: '120', target: 120, suffix: '', label: 'minuti complessivi · circa 9 min a capitolo' },
      { value: '2', target: 2, suffix: '', label: 'lingue · italiano e inglese, registrate da madrelingua' },
      { value: '∞', target: null, suffix: '', label: 'riascolti · per sempre tue, anche offline' },
    ]
  : [
      { value: '6', target: 6, suffix: '', label: 'narrative guides · six neighbourhoods of Bari' },
      { value: '120', target: 120, suffix: '', label: 'minutes total · about 9 min per chapter' },
      { value: '2', target: 2, suffix: '', label: 'languages · Italian and English, native voices' },
      { value: '∞', target: null, suffix: '', label: 'replays · yours forever, also offline' },
    ];
---
<section class="stats bg-surface-elev" data-stats-block>
  <div class="max-w-wrap mx-auto px-md sm:px-lg py-2xl lg:py-3xl">

    <div class="flex items-center gap-sm mb-md">
      <span class="block w-7 h-px bg-accent"></span>
      <span class="text-[11px] font-semibold tracking-[0.24em] uppercase text-accent">
        {eyebrow}
      </span>
    </div>

    <h2 class="font-display text-ink text-[clamp(1.7rem,3.6vw,2.5rem)] leading-[1.15] tracking-[-0.012em] max-w-[28ch] mb-2xl">
      {heading}
    </h2>

    <dl class="stats-grid grid grid-cols-2 lg:grid-cols-4 gap-lg lg:gap-xl m-0 p-0">
      {stats.map((s, i) => (
        <div class="stat-cell" style={`--idx:${i}`}>
          <dt class="sr-only">{s.label}</dt>
          <dd class="m-0 p-0">
            <span
              class="stat-value block font-display font-light text-accent text-[clamp(3rem,6vw,4.8rem)] leading-none mb-sm"
              data-target={s.target ?? ''}
              data-final={s.value}
              data-suffix={s.suffix}
              style="font-variant-numeric: tabular-nums;"
            >{s.target !== null ? '0' : s.value}</span>
            <span aria-hidden="true" class="block w-8 h-px bg-border mb-sm"></span>
            <span class="block font-body text-sm text-ink-muted leading-snug max-w-[24ch]">
              {s.label}
            </span>
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .stat-cell {
    opacity: 0;
    transform: translateY(12px);
    animation: statIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--idx, 0) * 90ms + 120ms);
  }

  /* When count-up runs, give the value a subtle accent emphasis */
  .stat-value[data-running="true"] {
    transform: translateY(0);
    opacity: 1;
  }

  @keyframes statIn {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-cell {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  (() => {
    const block = document.querySelector<HTMLElement>('[data-stats-block]');
    if (!block) return;

    const values = block.querySelectorAll<HTMLElement>('.stat-value');
    if (!values.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // If reduced motion: snap straight to final values, no animation
    if (reduced) {
      values.forEach((el) => {
        const final = el.dataset.final ?? '';
        el.textContent = final;
      });
      return;
    }

    // Ease-out quart — same curve as the rest of the page (--ease-out-quart)
    const easeOutQuart = (t: number): number => 1 - Math.pow(1 - t, 4);

    const animate = (el: HTMLElement) => {
      const targetStr = el.dataset.target ?? '';
      const final = el.dataset.final ?? '';
      const suffix = el.dataset.suffix ?? '';
      const target = parseFloat(targetStr);

      // Non-numeric (e.g. ∞) — just fade in the final glyph
      if (!targetStr || isNaN(target)) {
        el.textContent = final;
        el.dataset.running = 'true';
        return;
      }

      const duration = 1400; // ms
      const start = performance.now();

      const tick = (now: number) => {
        const elapsed = now - start;
        const t = Math.min(1, elapsed / duration);
        const eased = easeOutQuart(t);
        const current = Math.round(target * eased);
        el.textContent = current.toString() + suffix;

        if (t < 1) {
          requestAnimationFrame(tick);
        } else {
          el.textContent = final;
        }
      };

      el.dataset.running = 'true';
      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target as HTMLElement;
          if (el.dataset.running === 'true') continue;
          // Stagger between values for editorial rhythm
          const idx = Array.from(values).indexOf(el);
          window.setTimeout(() => animate(el), idx * 90);
          observer.unobserve(el);
        }
      },
      { threshold: 0.4, rootMargin: '0px 0px -10% 0px' }
    );

    values.forEach((el) => observer.observe(el));
  })();
</script>
