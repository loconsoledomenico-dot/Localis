---
import { type Lang } from '../lib/i18n';
import PhoneMockup from './PhoneMockup.astro';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const masthead_l = lang === 'it' ? 'Edizione 01 — Bari' : 'Edition 01 — Bari';
const masthead_r = lang === 'it' ? 'Sei guide narrative' : 'Six narrative guides';
const heading1 = lang === 'it' ? 'Bari ti parla.' : 'Bari speaks to you.';
const heading2 = lang === 'it' ? 'Se la sai ascoltare.' : 'If you know how to listen.';
const lede = lang === 'it'
  ? 'Sei storie vere registrate sui luoghi reali. Apri il browser, premi play, cammina nei vicoli mentre tutto è già accaduto.'
  : 'Six real stories recorded on real places. Open your browser, press play, walk the alleys while everything has already happened.';
const ctaPrimary = lang === 'it' ? 'Ascolta un assaggio · 60s' : 'Listen a teaser · 60s';
const ctaSecondary = lang === 'it' ? 'Sfoglia le sei guide' : 'Browse the six guides';
const microline = lang === 'it' ? 'Senza app. Funziona offline. Italiano e inglese.' : 'No app. Works offline. Italian and English.';

const deviceCaption = lang === 'it'
  ? 'Funziona dal browser. Niente app, niente account.'
  : 'Works in your browser. No app, no signup.';
---
<section class="hero relative bg-surface">
  <div class="max-w-wrap mx-auto px-md sm:px-lg pt-lg sm:pt-xl pb-2xl lg:pb-3xl">

    <!-- MASTHEAD strip — hairline + small caps, like a 1960s travel magazine flag -->
    <div class="hero-masthead flex items-baseline justify-between gap-md border-t border-border pt-sm mb-2xl lg:mb-3xl">
      <span class="text-[10px] font-semibold tracking-[0.32em] uppercase text-ink-subtle">
        {masthead_l}
      </span>
      <span class="hidden sm:inline text-[10px] font-semibold tracking-[0.28em] uppercase text-ink-subtle">
        {masthead_r}
      </span>
    </div>

    <!-- 12-col editorial grid: gutter (1) | headline (7) | photo plate (4) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-md lg:gap-xl items-start">

      <!-- Gutter chapter number — bleeds outside on lg, magazine flourish -->
      <aside class="hidden lg:block lg:col-span-1 relative" aria-hidden="true">
        <span class="hero-chapter font-display italic font-light text-[11rem] leading-[0.8] text-accent/12 select-none block -ml-md">
          01
        </span>
      </aside>

      <!-- HEADLINE column -->
      <div class="lg:col-span-7 lg:pr-lg flex flex-col">
        <h1 class="hero-h1 font-display text-ink leading-[0.96] tracking-[-0.018em] m-0">
          <span class="block font-light text-[clamp(2.6rem,7vw,4.6rem)]">{heading1}</span>
          <em class="block font-normal italic text-[clamp(2.2rem,6vw,3.8rem)] text-accent mt-2xs">{heading2}</em>
        </h1>

        <p class="hero-lede mt-lg text-base sm:text-lg leading-relaxed text-ink-muted max-w-[44ch]">
          {lede}
        </p>

        <div class="hero-actions mt-lg flex flex-col sm:flex-row gap-sm">
          <a
            href="#assaggio"
            class="inline-flex items-center justify-center gap-xs px-lg py-md rounded-md font-semibold text-sm bg-ink text-surface hover:bg-ink/90 transition-[background-color,transform] duration-fast hover:-translate-y-[1px] active:translate-y-0 no-underline min-h-[48px]"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20 6 4"/></svg>
            {ctaPrimary}
          </a>
          <a
            href="#guide"
            class="inline-flex items-center justify-center gap-xs px-lg py-md rounded-md font-semibold text-sm border border-ink text-ink hover:bg-ink hover:text-surface transition-colors duration-fast no-underline min-h-[48px]"
          >
            {ctaSecondary}
          </a>
        </div>

        <p class="hero-microline font-display italic text-sm text-ink-subtle mt-md max-w-[44ch]">
          {microline}
        </p>
      </div>

      <!-- DEVICE column — sober phone mockup with Localis UI inside -->
      <figure class="hero-figure lg:col-span-4 m-0 flex flex-col items-center">
        <PhoneMockup lang={lang} tilt={true} />
        <figcaption class="hero-caption mt-md flex items-baseline gap-sm text-ink-subtle self-stretch">
          <span class="font-body font-semibold text-[10px] tracking-[0.22em] uppercase whitespace-nowrap pt-[2px]">
            Tav. I
          </span>
          <span class="font-display italic text-[13px] leading-snug text-ink-muted max-w-[40ch]">
            {deviceCaption}
          </span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  /* Editorial reveal: hairline draws, masthead text fades, h1 stagger, plate slides in.
   * All transform/opacity only. Soft exponential easing. No bounce. */

  .hero-masthead {
    position: relative;
  }
  .hero-masthead::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-border);
    transform: scaleX(0);
    transform-origin: left;
    animation: ruleDraw 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }
  .hero-masthead > span {
    opacity: 0;
    animation: fadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.7s forwards;
  }

  .hero-h1 > span,
  .hero-h1 > em {
    opacity: 0;
    transform: translateY(14px);
    animation: textIn 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-h1 > span { animation-delay: 0.35s; }
  .hero-h1 > em    { animation-delay: 0.55s; }

  .hero-lede,
  .hero-actions,
  .hero-microline {
    opacity: 0;
    transform: translateY(10px);
    animation: textIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-lede      { animation-delay: 0.75s; }
  .hero-actions   { animation-delay: 0.9s; }
  .hero-microline { animation-delay: 1.05s; }

  .hero-figure {
    opacity: 0;
    transform: translateY(20px);
    animation: textIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
  }

  .hero-chapter {
    opacity: 0;
    animation: fadeIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.95s forwards;
  }

  @keyframes ruleDraw {
    to { transform: scaleX(1); }
  }
  @keyframes textIn {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-masthead::before,
    .hero-masthead > span,
    .hero-h1 > span,
    .hero-h1 > em,
    .hero-lede,
    .hero-actions,
    .hero-microline,
    .hero-figure,
    .hero-chapter {
      animation: none;
      transform: none;
      opacity: 1;
    }
  }
</style>
